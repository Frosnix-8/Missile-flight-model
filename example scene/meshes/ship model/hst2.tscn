[sub_resource type="GDScript" id="GDScript_12n53"]
resource_name = "debugmovement"
script/source = "extends Node3D
@export var armor_hardness := 40
@export var health := 1500
func TakeDamage(damage : float, hit_dictionary: Dictionary) -> void:
	print(\"HIT BY \", hit_dictionary[\"Missile\"])
	$AudioStreamPlayer3D.play(1.25)
	health -= damage
	if health <= 0:
		$AudioStreamPlayer3D.pitch_scale = 0.4
		$AudioStreamPlayer3D.play(1.25)
		print(\"DIEDDDDDD\")
		await get_tree().create_timer(3.0).timeout
		queue_free()
	print(\"HEALTH IS \", health)
"

