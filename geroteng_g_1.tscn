[sub_resource type="GDScript" id="GDScript_m3eeq"]
resource_name = "impactscript"
script/source = "extends ShapeCast3D
@export_category(\"DEBUG\")
@export var disabled := false
signal body_hit(collider: Node3D, location: Vector3)

func _physics_process(_delta: float) -> void:
	if disabled:
		set_physics_process(false)
	check_hit()
	
		
func check_hit(mult: float = 1.0) -> bool:
	if mult != 1.0:
		target_position *= mult
		await get_tree().physics_frame
		
		
	if get_collision_count() == 0:
		return false
	var hit := get_collider(0) 
	if hit:
		body_hit.emit(get_collider(0), get_collision_point(0))
	return true
	
"

