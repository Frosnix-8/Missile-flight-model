[sub_resource type="GDScript" id="GDScript_flrvv"]
resource_name = "debugmovement"
script/source = "extends Camera3D
var missile := preload(\"res://geroteng_g_1.tscn\")

func _ready() -> void:
	if get_parent().name != \"Collection 2\":
		current = false
		queue_free()
	else:
		current = true

var ticks := 0
func _physics_process(delta: float) -> void:
	ticks += 1
	if ticks % 15 != 0:
		return
	for x in get_node(\"../../\").get_children():
		if x is Missile_Guided:
			print(\"there are \", x.instance_count, \" missiles in the instance!\")
			break
	
func _process(delta: float) -> void:
	var input = Input.get_vector(\"ui_left\", \"ui_right\",\"ui_up\", \"ui_down\" )
	if input:
		position += basis * Vector3(input.x,0,input.y) * delta * 10
	if Input.is_action_just_pressed(\"ui_accept\"):
		for x in range(10):
			var new_missile : Missile_Guided = missile.instantiate()
			new_missile.target = get_node(\"../../Collection 3\")
			new_missile.owner_ship = get_parent()
			get_parent().get_parent().add_child(new_missile)
			new_missile.global_position = Vector3(107.86, -5, 0)
			new_missile.global_rotation = Vector3(0,deg_to_rad(111.2), 0)

			
			
func _unhandled_input(event: InputEvent) -> void:
	if event is InputEventMouseMotion and Input.mouse_mode == Input.MOUSE_MODE_CAPTURED:
		rotation.x -= event.relative.y * 0.001
		rotation.y -= event.relative.x * 0.001
	elif event is InputEventMouseButton:
		if event.pressed:
			Input.mouse_mode = Input.MOUSE_MODE_CAPTURED
		else:
			Input.mouse_mode = Input.MOUSE_MODE_VISIBLE
"

